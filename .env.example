# ==============================================================================
# MIS ACADEMY - CONFIGURACIÓN DEL MONOREPO (.env.example)
# ==============================================================================
# Copia este archivo como '.env' en la raíz y en el directorio 'backend-nestjs/'
# según corresponda y rellena con los valores correspondientes.

# ------------------------------------------------------------------------------
# 💻 CONFIGURACIÓN DEL SERVIDOR & ENTORNO
# ------------------------------------------------------------------------------
APP_ENV=development
APP_URL_BASE=http://localhost:5173
COOKIE_DOMAIN=localhost

# ------------------------------------------------------------------------------
# 🗄️ BASE DE DATOS (MySQL)
# ------------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=siteadmin_mis_academy

# ------------------------------------------------------------------------------
# 🔑 SEGURIDAD Y JWT (NestJS)
# ------------------------------------------------------------------------------
# JWT para Autenticación de Usuarios
JWT_SECRET=tu_secreto_para_autenticacion_muy_seguro_2026
JWT_EXPIRATION=15m

# JWT exclusivo para Refresh Tokens (debe ser diferente a JWT_SECRET)
REFRESH_JWT_SECRET=tu_secreto_para_refresh_tokens_muy_seguro_2026

# ------------------------------------------------------------------------------
# 📹 CONFIGURACIÓN DE VIDEO Y CIFRADO (Tolerante a fallos)
# ------------------------------------------------------------------------------
# Clave AES-256-CBC para cifrar IDs de videos (debe tener exactamente 32 caracteres)
VIDEO_ENCRYPTION_KEY=12345678901234567890123456789012
# JWT exclusivo para autorizar reproducciones de video
VIDEO_JWT_SECRET=tu_secreto_para_jwt_de_video_muy_seguro_2026
VIDEO_TOKEN_TTL=3600

# ------------------------------------------------------------------------------
# 📧 CONFIGURACIÓN DE CORREO (SMTP Mailer)
# ------------------------------------------------------------------------------
MAIL_HOST=misacademyonline.com
MAIL_PORT=465
MAIL_USERNAME=soporte@misacademyonline.com
MAIL_PASSWORD=
MAIL_FROM_NAME="MIS Academy"
MAIL_FROM_ADDRESS=soporte@misacademyonline.com

# ------------------------------------------------------------------------------
# 🔴 PERSISTENCIA DE SESIONES DE VIDEO (Redis - Opcional)
# ------------------------------------------------------------------------------
# Si se definen estas variables, las sesiones de video se almacenarán en Redis.
# Si no se definen o el servidor Redis no está activo, se usará memoria local.
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# 🌱 PARÁMETROS DE SEMILLAS (Database Seeds)
# ------------------------------------------------------------------------------
# Contraseñas requeridas en entornos de producción para poblar la base de datos
SEED_ADMIN_PASSWORD=
SEED_DOCENTE_PASSWORD=
SEED_TEACHERS_PASSWORD=
